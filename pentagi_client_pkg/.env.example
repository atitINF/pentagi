# PentAGI instance base URL (no trailing slash)
PENTAGI_BASE_URL=https://localhost:8443

# Bearer token — create one at https://<host>/api/v1/tokens
PENTAGI_API_TOKEN=your-api-token-here

# TLS verification (false = skip, suits default self-signed Docker cert)
PENTAGI_VERIFY_SSL=false

# Path to custom CA bundle (only used when PENTAGI_VERIFY_SSL=true)
# PENTAGI_CA_CERT=/path/to/ca.pem

# Max WebSocket reconnect attempts before raising StreamError
PENTAGI_WS_MAX_RETRIES=3
